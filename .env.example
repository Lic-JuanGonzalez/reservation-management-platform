# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=reservation_platform
POSTGRES_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── JWT (generate with: openssl rand -hex 32) ────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-64-char-random-string-before-deploying!!
JWT_REFRESH_SECRET_KEY=change-this-to-another-64-char-random-string-too!!
SECRET_KEY=change-this-application-secret-key-to-something-random!!

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM_EMAIL=noreply@reservehub.local

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
FLOWER_USER=admin
FLOWER_PASSWORD=flower123
